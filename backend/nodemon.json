{
  "watch": ["server.js", "routes/", "controllers/", "models/", "middleware/", "utils/"],
  "ignore": ["node_modules/", "uploads/", "temp/", "logs/", "*.test.js"],
  "ext": "js,json",
  "delay": 500,
  "verbose": false,
  "legacyWatch": false,
  "exec": "node --trace-warnings",
  "env": {
    "NODE_ENV": "development"
  }
}